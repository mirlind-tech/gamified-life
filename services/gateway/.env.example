# Mirlind Life OS - Gateway Service Configuration
# ================================================

# Server
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mirlind

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# JWT Configuration
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=change-this-in-production-minimum-256-bits-long-secret-key
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION_SECONDS=60

# Internal Service URLs
MESSAGING_SERVICE_URL=http://localhost:3001
FINANCE_SERVICE_URL=http://localhost:3002
AI_CORE_SERVICE_URL=http://localhost:3003
EDUCATION_SERVICE_URL=http://localhost:3004
DOCS_SERVICE_URL=http://localhost:3005

# AI Core (Phase 5)
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=user_memory
QDRANT_TOP_K=6
WHISPER_URL=http://localhost:9000/transcribe
WHISPER_MODEL=small

# Logging
RUST_LOG=info,gateway=debug,actix_web=info
